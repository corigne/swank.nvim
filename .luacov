-- luacov configuration for swank.nvim
-- Run: make coverage
-- Report is written to <project-root>/luacov.report.out

-- Anchor all paths to the project root regardless of invocation CWD
local here = debug.getinfo(1, "S").source:sub(2):match("^(.*[/\\])")
  or "./"

return {
  -- Only instrument our own source files
  include = {
    "lua/swank/",
  },
  exclude = {
    "tests/",
    "plugin/",
  },
  statsfile  = here .. "luacov.stats.out",
  reportfile = here .. "luacov.report.out",
  -- Don't exit Lua when coverage is done; let Neovim handle teardown
  runreport = false,
}
