      -- swank.nvim — Swank protocol: s-expression parser + serializer + event dispatch
      -- Parses only the subset of s-expressions used in Swank messages.

   24 local M = {}

      -- ---------------------------------------------------------------------------
      -- S-expression reader (minimal, Swank-message subset)
      -- Handles: lists, strings, symbols, keywords, integers, nil/t
      -- ---------------------------------------------------------------------------

      ---@param src string
      ---@param pos integer  (1-based)
      ---@return any, integer  (value, next_pos)
      local function read(src, pos)
        -- skip whitespace
 1167   while pos <= #src and src:sub(pos, pos):match("%s") do pos = pos + 1 end
  584   if pos > #src then error("unexpected end of input") end

  583   local ch = src:sub(pos, pos)

        -- list
  583   if ch == "(" then
  150     local result = {}
  150     pos = pos + 1
          while true do
 1977       while pos <= #src and src:sub(pos, pos):match("%s") do pos = pos + 1 end
 1288       if src:sub(pos, pos) == ")" then return result, pos + 1 end
            local val
  989       val, pos = read(src, pos)
  494       table.insert(result, val)
          end

        -- string
  433   elseif ch == '"' then
  117     local s = ""
  117     pos = pos + 1
 1527     while pos <= #src do
 1526       local c = src:sub(pos, pos)
 1526       if c == "\\" then
    3         pos = pos + 1
    6         s = s .. src:sub(pos, pos)
 1523       elseif c == '"' then
  116         return s, pos + 1
            else
 1407         s = s .. c
            end
 1410       pos = pos + 1
          end
    1     error("unterminated string")

        -- keyword or symbol
  316   elseif ch:match("[%a%d:%-_#%%%.%+%*%?%!%@%$%^%&%=%<%>%/%%|~`]") then
  314     local s = ""
 5224     while pos <= #src and not src:sub(pos, pos):match("[%s%(%)\"']") do
 4608       s = s .. src:sub(pos, pos)
 2304       pos = pos + 1
          end
  314     local upper = s:upper()
  314     if upper == "NIL" then return nil, pos
  294     elseif upper == "T" then return true, pos
  235     elseif s:match("^%-?%d+$") then return tonumber(s), pos
  147     else return s, pos  -- symbol or keyword as plain string
          end

        -- quote shorthand
    2   elseif ch == "'" then
          local val
    2     val, pos = read(src, pos + 1)
    1     return { "QUOTE", val }, pos

        else
    1     error("unexpected character: " .. ch)
        end
      end

      --- Parse a Swank s-expression message string into a Lua value
      ---@param src string
      ---@return any
   24 function M.parse(src)
  176   local ok, val = pcall(function()
   88     local v, _ = read(src, 1)
   85     return v
        end)
   88   if not ok then
    3     vim.notify("swank.nvim: parse error: " .. tostring(val), vim.log.levels.ERROR)
    3     return nil
        end
   85   return val
      end

      -- ---------------------------------------------------------------------------
      -- S-expression serializer
      -- ---------------------------------------------------------------------------

      ---@param val any
      ---@return string
   24 function M.serialize(val)
  668   local t = type(val)
  668   if val == nil then
    1     return "nil"
  667   elseif t == "boolean" then
   87     return val and "t" or "nil"
  580   elseif t == "number" then
   99     return tostring(math.floor(val))
  481   elseif t == "string" then
          -- Only emit as an unquoted symbol when the string is:
          --   1. a keyword   — starts with ':'  e.g. :ok, :swank-repl
          --   2. package-qualified — contains ':' e.g. swank:eval-and-grab-output
          --   3. an explicit CL operator we embed literally (QUOTE)
          -- Everything else (package names, symbol strings passed as args) is quoted.
  306     local is_symbol = val:match("^:[%a%d%-_%.]+$")        -- keyword
  306       or val:match("^[^:]+:[%a%d%-_%+%*%?%!%@%$%^%&%=%<%>%/%%|~%.#][%a%d%-_%+%*%?%!%@%$%^%&%=%<%>%/%%|~%.#:]*$") -- pkg:sym
  214       or val == "QUOTE"
  306     if is_symbol then
  167       return val
          else
  139       return '"' .. val:gsub("\\", "\\\\"):gsub('"', '\\"') .. '"'
          end
  175   elseif t == "table" then
  174     local parts = {}
  745     for _, v in ipairs(val) do
 1046       table.insert(parts, M.serialize(v))
          end
  174     return "(" .. table.concat(parts, " ") .. ")"
        else
    1     error("cannot serialize type: " .. t)
        end
      end

      -- ---------------------------------------------------------------------------
      -- Event dispatcher
      -- ---------------------------------------------------------------------------

      ---@type table<string, fun(payload: any)>
   24 local handlers = {}

      --- Register a handler for a Swank event type
      ---@param event string  e.g. ":return", ":debug", ":write-string"
      ---@param fn fun(payload: any)
   24 function M.on(event, fn)
  422   handlers[event:upper()] = fn
      end

      --- Dispatch a parsed Swank message to the appropriate handler
      ---@param msg any  parsed s-expression (a list)
   24 function M.dispatch(msg)
   45   if type(msg) ~= "table" or not msg[1] then return end
   41   local event = tostring(msg[1]):upper()
   41   local handler = handlers[event]
   41   if handler then
   80     handler(msg)
        else
    1     vim.notify("swank.nvim: unhandled event: " .. event, vim.log.levels.DEBUG)
        end
      end

   24 return M

