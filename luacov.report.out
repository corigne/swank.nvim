      -- swank.nvim — Swank protocol: s-expression parser + serializer + event dispatch
      -- Parses only the subset of s-expressions used in Swank messages.

   21 local M = {}

      -- ---------------------------------------------------------------------------
      -- S-expression reader (minimal, Swank-message subset)
      -- Handles: lists, strings, symbols, keywords, integers, nil/t
      -- ---------------------------------------------------------------------------

      ---@param src string
      ---@param pos integer  (1-based)
      ---@return any, integer  (value, next_pos)
      local function read(src, pos)
        -- skip whitespace
  923   while pos <= #src and src:sub(pos, pos):match("%s") do pos = pos + 1 end
  462   if pos > #src then error("unexpected end of input") end

  461   local ch = src:sub(pos, pos)

        -- list
  461   if ch == "(" then
  119     local result = {}
  119     pos = pos + 1
          while true do
 1553       while pos <= #src and src:sub(pos, pos):match("%s") do pos = pos + 1 end
 1014       if src:sub(pos, pos) == ")" then return result, pos + 1 end
            local val
  777       val, pos = read(src, pos)
  388       table.insert(result, val)
          end

        -- string
  342   elseif ch == '"' then
   92     local s = ""
   92     pos = pos + 1
 1161     while pos <= #src do
 1161       local c = src:sub(pos, pos)
 1161       if c == "\\" then
    3         pos = pos + 1
    6         s = s .. src:sub(pos, pos)
 1158       elseif c == '"' then
   92         return s, pos + 1
            else
 1066         s = s .. c
            end
 1069       pos = pos + 1
          end
****0     error("unterminated string")

        -- keyword or symbol
  250   elseif ch:match("[%a%d:%-_#%%%.%+%*%?%!%@%$%^%&%=%<%>%/%%|~`]") then
  249     local s = ""
 4066     while pos <= #src and not src:sub(pos, pos):match("[%s%(%)\"']") do
 3580       s = s .. src:sub(pos, pos)
 1790       pos = pos + 1
          end
  249     local upper = s:upper()
  249     if upper == "NIL" then return nil, pos
  232     elseif upper == "T" then return true, pos
  187     elseif s:match("^%-?%d+$") then return tonumber(s), pos
  117     else return s, pos  -- symbol or keyword as plain string
          end

        -- quote shorthand
    1   elseif ch == "'" then
          local val
    2     val, pos = read(src, pos + 1)
    1     return { "QUOTE", val }, pos

        else
****0     error("unexpected character: " .. ch)
        end
      end

      --- Parse a Swank s-expression message string into a Lua value
      ---@param src string
      ---@return any
   21 function M.parse(src)
