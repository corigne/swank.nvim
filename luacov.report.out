      -- swank.nvim — async TCP transport layer
      -- Uses vim.uv (libuv) for non-blocking socket I/O.
      -- Swank message framing: 6-hex-digit length prefix + s-expression payload.

   25 local M = {}

   25 local uv = vim.uv

      ---@class SwankTransport
      ---@field handle uv_tcp_t|nil
      ---@field buffer string
      ---@field on_message fun(msg: string)
      ---@field on_disconnect fun()
   25 local Transport = {}
   25 Transport.__index = Transport

      --- Create a new transport instance
      ---@param on_message fun(msg: string) called for each complete message received
      ---@param on_disconnect fun() called on socket close/error
      ---@return SwankTransport
   25 function Transport.new(on_message, on_disconnect)
   18   return setmetatable({
          handle = nil,
          buffer = "",
   18     on_message = on_message,
   18     on_disconnect = on_disconnect,
   18   }, Transport)
      end

      --- Connect to a Swank server
      ---@param host string
      ---@param port integer
      ---@param on_connect fun(err: string|nil)
   25 function Transport:connect(host, port, on_connect)
    5   local handle = uv.new_tcp()
   10   handle:connect(host, port, function(err)
    3     if err then
    1       handle:close()
    1       on_connect(err)
    1       return
          end
    2     self.handle = handle
    2     on_connect(nil)
    4     handle:read_start(function(read_err, data)
    4       vim.schedule(function()
    2         if read_err or not data then
    1           self:_on_close()
    1           return
              end
    1         self:_feed(data)
            end)
          end)
        end)
      end

      --- Send a raw message string (will be length-prefixed)
      ---@param payload string
   25 function Transport:send(payload)
    2   if not self.handle then
    1     vim.notify("swank.nvim: not connected", vim.log.levels.ERROR)
    1     return
        end
    1   local frame = string.format("%06x", #payload) .. payload
    1   self.handle:write(frame)
      end

      --- Disconnect the socket
   25 function Transport:disconnect()
    2   if self.handle then
    1     self.handle:close()
    1     self.handle = nil
        end
      end

      --- Internal: handle raw data from socket
      ---@param data string
   25 function Transport:_feed(data)
   56   self.buffer = self.buffer .. data
        while true do
   71     if #self.buffer < 6 then break end
   64     local len = tonumber(self.buffer:sub(1, 6), 16)
   32     if not len then
    1       vim.notify("swank.nvim: bad message frame", vim.log.levels.ERROR)
    1       self.buffer = ""
    1       break
          end
   31     if #self.buffer < 6 + len then break end
   15     local msg = self.buffer:sub(7, 6 + len)
   30     self.buffer = self.buffer:sub(7 + len)
   30     self.on_message(msg)
        end
      end

