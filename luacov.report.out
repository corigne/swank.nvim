   72     local v, _ = read(src, 1)
   71     return v
        end)
   72   if not ok then
    1     vim.notify("swank.nvim: parse error: " .. tostring(val), vim.log.levels.ERROR)
    1     return nil
        end
   71   return val
      end

      -- ---------------------------------------------------------------------------
      -- S-expression serializer
      -- ---------------------------------------------------------------------------

      ---@param val any
      ---@return string
   21 function M.serialize(val)
  538   local t = type(val)
  538   if val == nil then
    1     return "nil"
  537   elseif t == "boolean" then
   69     return val and "t" or "nil"
  468   elseif t == "number" then
   80     return tostring(math.floor(val))
  388   elseif t == "string" then
          -- Only emit as an unquoted symbol when the string is:
          --   1. a keyword   — starts with ':'  e.g. :ok, :swank-repl
          --   2. package-qualified — contains ':' e.g. swank:eval-and-grab-output
          --   3. an explicit CL operator we embed literally (QUOTE)
          -- Everything else (package names, symbol strings passed as args) is quoted.
  247     local is_symbol = val:match("^:[%a%d%-_%.]+$")        -- keyword
  247       or val:match("^[^:]+:[%a%d%-_%+%*%?%!%@%$%^%&%=%<%>%/%%|~%.#][%a%d%-_%+%*%?%!%@%$%^%&%=%<%>%/%%|~%.#:]*$") -- pkg:sym
  171       or val == "QUOTE"
