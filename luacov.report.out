      -- swank.nvim — blink.cmp completion source
      -- Provides symbol completions via swank:completions.
      -- Supports resolve() for lazy swank:describe-symbol documentation.
      -- Register in blink.cmp opts:
      --   providers = { swank = { name = "Swank", module = "swank.blink_source" } }
      --   per_filetype = { lisp = { "swank", "buffer" }, commonlisp = { "swank", "buffer" } }

    2 local M = {}
    2 M.__index = M

      -- blink.cmp calls this to instantiate the source
    2 function M.new()
****0   return setmetatable({}, M)
      end

    2 function M:enabled()
    4   local ok, client = pcall(require, "swank.client")
    8   if not (ok and client.is_connected()) then return false end
        -- Yield to the LSP when one is attached; it provides completions natively.
    3   local bufnr = vim.api.nvim_get_current_buf()
    6   return #vim.lsp.get_clients({ bufnr = bufnr }) == 0
      end

    2 function M:get_trigger_characters()
****0   return { ":", "-" }
      end

      -- Extract the Lisp symbol prefix ending at the cursor
      local function symbol_prefix(line)
        -- CL symbols: letters, digits, -, +, *, /, <, >, =, !, ?, :, &, %, #, @, $, ^, ~, ., |, \
    5   return line:match("[%w%-%+%*%/%<%>%=%!%?%:%&%#%@%$%%^~%.]+$") or ""
      end

    2 function M:get_completions(ctx, callback)
    6   local ok, client = pcall(require, "swank.client")
   12   if not ok or not client.is_connected() then
    1     callback({ items = {}, isIncomplete = false })
    1     return
        end

        -- blink context: ctx.line is the full line, ctx.cursor is {row, col}
    9   local line_before = ctx.line and ctx.line:sub(1, ctx.cursor and ctx.cursor[2] or 0) or ""
    5   local prefix = symbol_prefix(line_before)
    5   if prefix == "" then
    2     callback({ items = {}, isIncomplete = false })
    2     return
        end

    3   local pkg = client.get_package()

    6   client.rex({ "swank:completions", prefix, pkg }, function(result)
          -- swank:completions returns (:ok ((comp1 comp2 ...) "longest-prefix"))
    2     if type(result) ~= "table" or result[1] ~= ":ok" then
    1       callback({ items = {}, isIncomplete = false })
    1       return
          end
    1     local payload = result[2]
          -- payload[1] = list of completion strings, payload[2] = longest-prefix string
    1     local list = (type(payload) == "table" and payload[1]) or {}
    1     if type(list) ~= "table" then
****0       callback({ items = {}, isIncomplete = false })
****0       return
          end
    1     local items = {}
    4     for _, c in ipairs(list) do
    3       if type(c) == "string" then
    6         table.insert(items, {
    3           label            = c,
    3           kind             = vim.lsp.protocol.CompletionItemKind.Function,
    3           insertText       = c,
    3           filterText       = c,
              })
            end
          end
    1     callback({ items = items, isIncomplete = false })
        end)
      end

      --- Lazily enrich a completion item with swank:describe-symbol output.
      --- blink.cmp calls this when the user dwells on an item in the menu.
    2 function M:resolve(item, callback)
    5   local ok, client = pcall(require, "swank.client")
